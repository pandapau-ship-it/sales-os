# Supabase-Projekt-Zugangsdaten
# Findest du in deinem Supabase-Dashboard unter: Project Settings → API
VITE_SUPABASE_URL=deine-supabase-projekt-url-hier
VITE_SUPABASE_ANON_KEY=dein-supabase-anon-key-hier

# Auth-Entwickler-Schnellzugang (nur lokal, nie in Produktion)
# Auf "true" setzen, um lokal ohne echten Login zu testen.
# Funktioniert NUR im lokalen Dev-Server (npm run dev), niemals im
# Produktions-Build — sicher, auch wenn's im Repo landet.
VITE_DEV_AUTH_BYPASS=false